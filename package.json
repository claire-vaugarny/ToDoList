{
  "name": "todolist",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:back\"",
    "dev:front": "npm --prefix ToDoList_Frontend run dev",
    "dev:back": "json-server --watch ToDoList_Backend/db.json --port 3001",
    "build": "npm --prefix ToDoList_Frontend run build",
    "preview": "npm --prefix ToDoList_Frontend run preview"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "json-server": "^1.0.0-beta.15"
  }
}